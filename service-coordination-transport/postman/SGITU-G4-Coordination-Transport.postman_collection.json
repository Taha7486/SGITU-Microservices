{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "SGITU G4 — Coordination des transports",
		"description": "Scénarios de test pour le microservice G4 (Spring Boot). Exécuter «Auth — login» en premier pour remplir la variable `accessToken`.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8084" },
		{ "key": "accessToken", "value": "" },
		{ "key": "ligneId", "value": "1" },
		{ "key": "trajetId", "value": "1" },
		{ "key": "arretId", "value": "1" },
		{ "key": "horaireId", "value": "1" },
		{ "key": "affectationId", "value": "1" },
		{ "key": "missionId", "value": "1" },
		{ "key": "eventId", "value": "1" },
		{ "key": "vehiculeId", "value": "VH-001" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
	},
	"item": [
		{
			"name": "00 — Auth",
			"item": [
				{
					"name": "Login (JWT)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"  const j = pm.response.json();",
									"  pm.collectionVariables.set('accessToken', j.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"gestionnaire.reseau\",\n  \"password\": \"password\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/login",
						"description": "Comptes démo (mot de passe : password) : gestionnaire.reseau = G4_OPERATOR (réseau), gestionnaire.flotte = G4_DISPATCHER (flotte), admin.technique = G4_ADMIN (supervision + tout), g10.integration = gateway."
					}
				}
			]
		},
