{
  "info": {
    "_postman_id": "g8-live-demo-kafka-collection",
    "name": "G8 Live Demo",
    "description": "Live classroom demo — Kafka-first integration showcase.\n\n**Order:** Phase 0 → 6. Do not run before class (keeps Mongo empty).\n\n**Before class:** build containers only (`docker compose up -d --build ...`).\n**During class:** run phase by phase.\n\n**G3 note:** after request 2.1, read the 6-digit code from `docker logs g3-user-service --tail=30` and set collection variable `g3VerificationCode` before 2.2.\n\n**Resilience note:** Phase 5 — stop G5 with `docker stop notification-service` before running it.\n\nGroups showcased: **G2, G3, G7, G9** (G1/G6 excluded).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var today = new Date().toISOString().split('T')[0];",
          "pm.collectionVariables.set('today', today);",
          "pm.collectionVariables.set('nowTs', new Date().toISOString());",
          "if (!pm.collectionVariables.get('demoRunId')) {",
          "  pm.collectionVariables.set('demoRunId', String(Date.now()));",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8088" },
    { "key": "g2BaseUrl", "value": "http://localhost:8082" },
    { "key": "g3BaseUrl", "value": "http://localhost:8083/api" },
    { "key": "g7BaseUrl", "value": "http://localhost:8087" },
    { "key": "g9BaseUrl", "value": "http://localhost:8089/api/incidents" },
    { "key": "g5BaseUrl", "value": "http://localhost:8085" },
    { "key": "prometheusUrl", "value": "http://localhost:9090" },
    { "key": "grafanaUrl", "value": "http://localhost:3000" },
    { "key": "jwtSecret", "value": "your_jwt_secret_here_min_256_bits", "description": "Last JWT_SECRET in root .env" },
    { "key": "authToken", "value": "" },
    { "key": "g3Email", "value": "" },
    { "key": "g3UserId", "value": "" },
    { "key": "g3VerificationCode", "value": "", "description": "Paste 6-digit code from G3 logs after 2.1" },
    { "key": "g7VehicleId", "value": "" },
    { "key": "g9IncidentId", "value": "" },
    { "key": "g9IncidentReference", "value": "" },
    { "key": "g2PlanId", "value": "" },
    { "key": "demoRunId", "value": "" }
  ],
  "item": [
    {
      "name": "PHASE 0 — Platform ready",
      "description": "Confirm G8, G5, Prometheus and all Kafka sender groups are up.",
      "item": [
        { "name": "0.1 G8 health", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/actuator/health" } },
        { "name": "0.2 G5 health", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{g5BaseUrl}}/api/notifications/health" } },
        { "name": "0.3 Prometheus healthy", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{prometheusUrl}}/-/healthy" } },
        { "name": "0.4 G3 health", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{g3BaseUrl}}/actuator/health" } },
        { "name": "0.5 G7 health", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{g7BaseUrl}}/actuator/health" } },
        { "name": "0.6 G9 health", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{g9BaseUrl}}/actuator/health" } },
        { "name": "0.7 G2 health (abonnement)", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{g2BaseUrl}}/actuator/health" } }
      ]
    },
    {
      "name": "PHASE 1 — G8 security (JWT)",
      "item": [
        {
          "name": "1.1 Dashboard without token (401)",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/dashboard" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('401 without JWT', function () { pm.response.to.have.status(401); });"] } }]
        },
        {
          "name": "1.2 Generate G8 JWT",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/dashboard" },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var secret = pm.collectionVariables.get('jwtSecret');",
                  "var header = { alg: 'HS256', typ: 'JWT' };",
                  "var now = Math.floor(Date.now() / 1000);",
                  "var payload = { sub: 'live-demo', roles: ['ROLE_ADMIN', 'ROLE_ANALYTICS'], iat: now, exp: now + 7200 };",
                  "function b64url(str) { return btoa(str).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,''); }",
                  "var h = b64url(JSON.stringify(header));",
                  "var p = b64url(JSON.stringify(payload));",
                  "var input = h + '.' + p;",
                  "var sig = CryptoJS.enc.Base64.stringify(CryptoJS.HmacSHA256(input, secret)).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,'');",
                  "pm.collectionVariables.set('authToken', input + '.' + sig);"
                ]
              }
            },
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('JWT works', function () { pm.response.to.have.status(200); });"] } }
          ]
        }
      ]
    },
    {
      "name": "PHASE 2 — Kafka senders (G3 → G7 → G9 → G2)",
      "description": "Trigger real microservices so they publish to Kafka (or G2 batch). G8 consumes in the background.\n\n**Say to teacher:** each call hits another team's API; G8 listens on shared Kafka topics.",
      "item": [
        {
          "name": "2A — G3 Users → g8-user-events",
          "item": [
            {
              "name": "2A.1 G3 Create user",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"demo-g3-{{demoRunId}}@sgitu.ma\",\n  \"password\": \"Secret123!\",\n  \"role\": \"ROLE_PASSENGER\",\n  \"profile\": {\n    \"firstName\": \"Demo\",\n    \"lastName\": \"Passenger\",\n    \"phone\": \"0600000000\",\n    \"address\": \"SGITU Live Demo\",\n    \"birthDate\": \"1998-01-01\"\n  }\n}"
                },
                "url": "{{g3BaseUrl}}/users"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('User created', function () { pm.response.to.have.status(201); });",
                      "var j = pm.response.json();",
                      "pm.collectionVariables.set('g3UserId', String(j.id));",
                      "pm.collectionVariables.set('g3Email', j.email);"
                    ]
                  }
                }
              ]
            },
            {
              "name": "2A.2 G3 Verify email → Kafka publish",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{g3Email}}\",\n  \"code\": \"{{g3VerificationCode}}\"\n}"
                },
                "url": "{{g3BaseUrl}}/auth/verify-email",
                "description": "**Presenter step — get the 6-digit code:**\n\n1. Redis (fastest): `docker exec g3-redis redis-cli GET \"email_verification:{{g3Email}}\"`\n2. Or logs: `docker logs g3-user-service 2>&1 | Select-String \"VERIFICATION CODE FOR {{g3Email}}\"`\n\nDo **not** use `--tail=30` — recent logs are mostly Hibernate noise.\n\nPaste code into variable `g3VerificationCode`, then send.\n\nThis publishes `{ userId, action: active }` to **g8-user-events**."
              },
              "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Email verified', function () { pm.response.to.have.status(200); });"] } }]
            }
          ]
        },
        {
          "name": "2B — G7 Vehicles → g8.vehicule.status",
          "item": [
            {
              "name": "2B.1 G7 Create vehicle",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-User-Id", "value": "demo-g7" },
                  { "key": "X-Roles", "value": "ROLE_ADMIN_G7" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"immatriculation\": \"DEMO-{{demoRunId}}\",\n  \"type\": \"BUS\",\n  \"ligne\": \"L-DEMO\"\n}"
                },
                "url": "{{g7BaseUrl}}/api/suivi-vehicules/vehicules"
              },
              "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Vehicle created', function () { pm.response.to.have.status(201); });", "pm.collectionVariables.set('g7VehicleId', String(pm.response.json().id));"] } }]
            },
            {
              "name": "2B.2 G7 Set status EN_SERVICE → Kafka",
              "request": {
                "auth": { "type": "noauth" },
                "method": "PUT",
                "header": [
                  { "key": "X-User-Id", "value": "demo-g7" },
                  { "key": "X-Roles", "value": "ROLE_ADMIN_G7" }
                ],
                "url": "{{g7BaseUrl}}/api/suivi-vehicules/vehicules/{{g7VehicleId}}/statut?statut=EN_SERVICE",
                "description": "Publishes vehicle status to **g8.vehicule.status**."
              }
            },
            {
              "name": "2B.3 G7 Post GPS position → Kafka",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-User-Id", "value": "demo-g7" },
                  { "key": "X-Roles", "value": "ROLE_ADMIN_G7" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"vehiculeId\": \"{{g7VehicleId}}\",\n  \"latitude\": 33.5731,\n  \"longitude\": -7.5898,\n  \"vitesse\": 8.0,\n  \"cap\": 180.0\n}"
                },
                "url": "{{g7BaseUrl}}/api/suivi-vehicules/positions",
                "description": "Also refreshes **g8.vehicule.status** with speed/line data."
              }
            }
          ]
        },
        {
          "name": "2C — G9 Incidents → incident.analytique.topic",
          "item": [
            {
              "name": "2C.1 G9 Signaler incident",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{g9PassengerToken}}" },
                  { "key": "X-User-Id", "value": "9001" },
                  { "key": "X-User-Role", "value": "ROLE_PASSENGER" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"type\": \"ACCIDENT\",\n  \"description\": \"Live demo incident {{demoRunId}}\",\n  \"dateIncident\": \"{{nowTs}}\",\n  \"latitude\": 33.5731,\n  \"longitude\": -7.5898,\n  \"vehiculeId\": \"VEH-DEMO-{{demoRunId}}\",\n  \"ligneTransport\": \"L-DEMO\",\n  \"preuves\": []\n}"
                },
                "url": "{{g9BaseUrl}}/signaler",
                "description": "Signalement alone does NOT publish to G8. Cancellation/closing does."
              },
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "var secret = pm.collectionVariables.get('jwtSecret');",
                      "var header = { alg: 'HS256', typ: 'JWT' };",
                      "var now = Math.floor(Date.now() / 1000);",
                      "var payload = { sub: 'demo-passenger', roles: ['ROLE_PASSENGER'], iat: now, exp: now + 7200 };",
                      "function b64url(str) { return btoa(str).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,''); }",
                      "var h = b64url(JSON.stringify(header)); var p = b64url(JSON.stringify(payload));",
                      "var input = h + '.' + p;",
                      "var sig = CryptoJS.enc.Base64.stringify(CryptoJS.HmacSHA256(input, secret)).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,'');",
                      "pm.collectionVariables.set('g9PassengerToken', input + '.' + sig);"
                    ]
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Incident created', function () { pm.response.to.have.status(201); });",
                      "var j = pm.response.json();",
                      "pm.collectionVariables.set('g9IncidentId', String(j.incidentId));",
                      "pm.collectionVariables.set('g9IncidentReference', j.reference);"
                    ]
                  }
                }
              ]
            },
            {
              "name": "2C.2 G9 Cancel incident → Kafka to G8",
              "request": {
                "auth": { "type": "noauth" },
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{g9SupervisorToken}}" },
                  { "key": "X-User-Id", "value": "9002" },
                  { "key": "X-User-Role", "value": "ROLE_SUPERVISOR" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"motif\": \"Live demo cancellation {{demoRunId}}\"\n}" },
                "url": "{{g9BaseUrl}}/{{g9IncidentId}}/annuler",
                "description": "Publishes dossier to **incident.analytique.topic**. G8 consumer persists sourceType INCIDENT."
              },
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "var secret = pm.collectionVariables.get('jwtSecret');",
                      "var header = { alg: 'HS256', typ: 'JWT' };",
                      "var now = Math.floor(Date.now() / 1000);",
                      "var payload = { sub: 'demo-supervisor', roles: ['ROLE_SUPERVISOR'], iat: now, exp: now + 7200 };",
                      "function b64url(str) { return btoa(str).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,''); }",
                      "var h = b64url(JSON.stringify(header)); var p = b64url(JSON.stringify(payload));",
                      "var input = h + '.' + p;",
                      "var sig = CryptoJS.enc.Base64.stringify(CryptoJS.HmacSHA256(input, secret)).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,'');",
                      "pm.collectionVariables.set('g9SupervisorToken', input + '.' + sig);"
                    ]
                  }
                },
                { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Incident cancelled', function () { pm.response.to.have.status(204); });"] } }
              ]
            }
          ]
        },
        {
          "name": "2D — G2 Subscriptions → G8 batch",
          "description": "G2 stores AnalytiqueTrace on souscription, then relays via POST /api/events/batch (same contract as G2 scheduler). Requires G3 user from 2A.",
          "item": [
            {
              "name": "2D.1 G2 Create plan (admin JWT)",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{g2AdminToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"nomPlan\": \"Demo Plan {{demoRunId}}\",\n  \"description\": \"Live demo subscription plan\",\n  \"prix\": 35.0,\n  \"duree\": \"MENSUEL\",\n  \"categorie\": \"ROLE_PASSENGER\",\n  \"transportType\": \"BUS\",\n  \"estActif\": \"ACTIF\",\n  \"maxDesactivation\": 1,\n  \"minJoursEntreDesactivation\": 1,\n  \"maxPeriodeDesactivation\": 3\n}"
                },
                "url": "{{g2BaseUrl}}/plans"
              },
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "var secret = pm.collectionVariables.get('jwtSecret');",
                      "var header = { alg: 'HS256', typ: 'JWT' };",
                      "var now = Math.floor(Date.now() / 1000);",
                      "var payload = { sub: 'g2-admin-demo', roles: ['ROLE_ADMIN_G2'], iat: now, exp: now + 7200 };",
                      "function b64url(str) { return btoa(str).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,''); }",
                      "var h = b64url(JSON.stringify(header)); var p = b64url(JSON.stringify(payload));",
                      "var input = h + '.' + p;",
                      "var sig = CryptoJS.enc.Base64.stringify(CryptoJS.HmacSHA256(input, secret)).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,'');",
                      "pm.collectionVariables.set('g2AdminToken', input + '.' + sig);"
                    ]
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Plan created', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                      "pm.collectionVariables.set('g2PlanId', String(pm.response.json().idPlan));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "2D.2 G2 Subscribe (passenger JWT)",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{g2PassengerToken}}" }
                ],
                "url": "{{g2BaseUrl}}/abonnements/souscrire?userId={{g3UserId}}&planId={{g2PlanId}}",
                "description": "Creates AnalytiqueTrace row in G2 MySQL (SOUSCRIPTION_INITIALE)."
              },
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "var secret = pm.collectionVariables.get('jwtSecret');",
                      "var email = pm.collectionVariables.get('g3Email');",
                      "var header = { alg: 'HS256', typ: 'JWT' };",
                      "var now = Math.floor(Date.now() / 1000);",
                      "var payload = { sub: email, email: email, roles: ['ROLE_PASSENGER'], iat: now, exp: now + 7200 };",
                      "function b64url(str) { return btoa(str).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,''); }",
                      "var h = b64url(JSON.stringify(header)); var p = b64url(JSON.stringify(payload));",
                      "var input = h + '.' + p;",
                      "var sig = CryptoJS.enc.Base64.stringify(CryptoJS.HmacSHA256(input, secret)).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,'');",
                      "pm.collectionVariables.set('g2PassengerToken', input + '.' + sig);"
                    ]
                  }
                },
                { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Subscription created', function () { pm.response.to.have.status(201); });"] } }
              ]
            },
            {
              "name": "2D.3 G8 Accept G2 batch (simulates G2 scheduler)",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "[\n  {\n    \"timestamp\": \"{{nowTs}}\",\n    \"userId\": \"USR-{{g3UserId}}\",\n    \"action\": \"created\",\n    \"planType\": \"MONTHLY_PASSENGER\"\n  }\n]"
                },
                "url": "{{baseUrl}}/api/events/batch",
                "description": "In production G2 AnalyseClient POSTs this every 30 min. We relay immediately for the demo.\n\n**Say:** G2 trace → G8 SUBSCRIPTION ingestion."
              },
              "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Batch accepted', function () { pm.expect(pm.response.json().status).to.eql('SUCCESS'); });"] } }]
            }
          ]
        },
        {
          "name": "2E — Pause: let G8 consume Kafka (~10 s)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health",
            "description": "Wait ~10 seconds before Phase 3.\n\nOptional Kafka proof (2A–2C only; 2D is REST batch):\n`docker logs g8-analytics-service --tail=100 | findstr /i Kafka`\n\nExpect: `Kafka [USER]`, `Kafka [VEHICLE]`, `Kafka [INCIDENT]` with accepted=1."
          }
        }
      ]
    },
    {
      "name": "PHASE 3 — G8 analytics & KPIs",
      "description": "Show that Kafka events were aggregated into business indicators.",
      "item": [
        { "name": "3.1 Run analytics job", "request": { "method": "GET", "url": "{{baseUrl}}/test/run" } },
        { "name": "3.2 List snapshots", "request": { "method": "GET", "url": "{{baseUrl}}/test/snapshots" } },
        { "name": "3.3 Dashboard (all KPIs)", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/dashboard" } },
        { "name": "3.4 Users stats (G3 path)", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/users/stats" } },
        { "name": "3.5 Vehicles activity (G7 path)", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/vehicles/activity" } },
        { "name": "3.6 Incidents stats (G9 path)", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/incidents/stats" } },
        { "name": "3.7 Subscriptions stats (G2 path)", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/subscriptions/stats" } }
      ]
    },
    {
      "name": "PHASE 4 — Threshold alerts → G5",
      "description": "Push threshold-violating data via REST (fast), run job, show metrics + G5 DB proof in terminal.",
      "item": [
        {
          "name": "4.1 Ingest delayed vehicles (threshold)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
