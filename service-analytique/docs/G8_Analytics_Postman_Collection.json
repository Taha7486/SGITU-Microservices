                "v1",
                "ingestion",
                "payments"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"transactionId\": \"TXN-001\",\n    \"status\": \"completed\",\n    \"line\": \"L1\",\n    \"timestamp\": \"{{t_0830}}\",\n    \"amount\": 25.50,\n    \"method\": \"CARD\"\n  },\n  {\n    \"transactionId\": \"TXN-002\",\n    \"status\": \"completed\",\n    \"zone\": \"Z_CENTER\",\n    \"timestamp\": \"{{t_0900}}\",\n    \"amount\": 10.00,\n    \"method\": \"CASH\"\n  },\n  {\n    \"transactionId\": \"TXN-003\",\n    \"status\": \"completed\",\n    \"line\": \"L2\",\n    \"timestamp\": \"{{t_1015}}\",\n    \"amount\": 50.00,\n    \"method\": \"CARD\"\n  },\n  {\n    \"transactionId\": \"TXN-004\",\n    \"status\": \"completed\",\n    \"line\": \"L3\",\n    \"timestamp\": \"{{t_1200}}\",\n    \"amount\": 15.75,\n    \"method\": \"CASH\"\n  },\n  {\n    \"transactionId\": \"TXN-005\",\n    \"status\": \"failed\",\n    \"line\": \"L1\",\n    \"timestamp\": \"{{t_1300}}\",\n    \"amount\": 25.50,\n    \"method\": \"CARD\"\n  }\n]",
              "options": {
                "raw": {
