{
  "info": {
    "_postman_id": "g8-analytics-collection",
    "name": "G8 Analytics Service",
    "description": "Full test suite for the G8 Analytics Service. Run requests in order:\n1. Ingest data (01-06)\n2. Wait ~60 seconds for the scheduler\n3. Read analytics (07-14)\n4. Generate and fetch a report (15-16)\n5. Error/edge cases (17-19)\n6. Kafka mock tests (20-23) — simulate G7 vehicle and G9 incident Kafka messages without a broker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Auto-generate yesterday's timestamps for Phase 1 ingestion payloads",
          "var d = new Date();",
          "d.setDate(d.getDate() - 1);",
          "var yyyy = d.getFullYear();",
          "var mm = String(d.getMonth()+1).padStart(2,'0');",
          "var dd = String(d.getDate()).padStart(2,'0');",
          "var yesterday = yyyy+'-'+mm+'-'+dd;",
          "var today = new Date().toISOString().split('T')[0];",
          "pm.collectionVariables.set('today', today);",
          "// Generate ISO timestamps at various hours yesterday (always in the past)",
          "var hours = ['08:00','08:05','08:10','08:30','08:45','09:00','09:15','10:00','10:15','11:00','12:00','13:00','14:00','15:30','17:00','17:10','17:30','17:50','18:05'];",
          "hours.forEach(function(h){ pm.collectionVariables.set('t_'+h.replace(':',''), yesterday+'T'+h+':00Z'); });"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8088",
      "type": "string"
    },
    {
      "key": "reportId",
      "value": "",
      "type": "string",
      "description": "Populated automatically after running request 14"
    },
    {
      "key": "today",
      "value": "",
      "type": "string",
      "description": "Auto-set to today's date (YYYY-MM-DD) by the collection pre-request script"
    }
  ],
  "item": [
    {
      "name": "--- PHASE 1: Ingest Data ---",
      "item": [
        {
          "name": "01 - Ingest Tickets",
          "request": {
            "method": "POST",
            "header": [
