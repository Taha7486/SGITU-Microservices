	"item": [
		{
			"name": "1. Cycle de vie de l'Incident",
			"item": [
				{
					"name": "1.1 Signaler un incident",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200 or 201\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"if (jsonData.incidentId) {",
									"    pm.collectionVariables.set(\"incidentId\", jsonData.incidentId);",
									"    console.log(\"ID de l'incident sauvegardé : \" + jsonData.incidentId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-User-Id",
								"value": "1"
							},
							{
								"key": "X-User-Role",
								"value": "VOYAGEUR"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"type\": \"ACCIDENT\",\n  \"description\": \"Accident léger entre deux bus à la station centrale.\",\n  \"dateIncident\": \"2024-05-08T10:30:00\",\n  \"latitude\": 33.5731,\n  \"longitude\": -7.5898,\n  \"vehiculeId\": \"BUS-123\",\n  \"preuves\": [\n    {\n      \"type\": \"PHOTO\",\n      \"fichierBase64\": \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8/5+hHgAHggJ/PchI7wAAAABJRU5ErkJggg==\",\n      \"description\": \"Vue d'ensemble de l'accident\"\n    }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/signaler",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"signaler"
							]
						}
					},
					"response": []
				},
