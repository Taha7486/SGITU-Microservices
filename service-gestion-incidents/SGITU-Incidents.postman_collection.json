{
	"info": {
		"_postman_id": "870a4a79-171e-4504-9d33-95e761c7a2a3",
		"name": "SGITU-Gestion-Incidents",
		"description": "Collection pour tester les APIs du service de gestion des incidents en suivant le cycle de vie logique.",
